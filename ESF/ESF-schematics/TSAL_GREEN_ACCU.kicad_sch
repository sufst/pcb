	)
	(text "For this to go high, the\nfollowing must be true:\n- TS_ON is high (else the\n  latch will be in reset).\n- The shutdown loop has\n  been closed for at least\n  0.47s (else the latch will\n  be in reset).\n- A rising edge on TS_ON\n  has been detected at least\n  0.47s after the shutdown\n  circuit was last open.\n\nThis last point guarantees\nrule EV4.11.4 (FSG 2026)\n"
		(exclude_from_sim no)
		(at 200.66 337.82 0)
		(effects
			(font
				(size 1.27 1.27)
			)
