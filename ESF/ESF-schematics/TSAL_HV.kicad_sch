	(text "SCS:\n- Red LED turns on when HV detected,\n  safe state = off, so red LED uses\n  HV_DETECTED signal (short to GND\n  means off = safe state)\n- Green LED turns on when HV not\n  detected, safe state = off, so\n  green LED uses ~{HV_DETECTED} \n  signal (short to GND means off =\n  safe state)"
		(exclude_from_sim no)
		(at 227.33 67.31 0)
