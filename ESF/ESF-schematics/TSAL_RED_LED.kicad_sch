	(text "SCS:\n- Red LED turns on when HV detected.\n  Safe state = off, so red LED uses\n  HV_DETECTED signal \n  (short to GND means off = safe state)"
		(exclude_from_sim no)
		(at 220.726 52.324 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "2ec51863-3350-4358-b5c7-5e837c496b04")
	)
	(text "12V Zener clamps gate voltage of Q3 to 12V,\nand prevents noise or low voltage \naccidentally triggering \"HV Detected\"\nsignal until 12V gate voltage.\n\nStarts conducting at 12V.\nOnce voltage through D14 creates \n1.24V drop across R60, U13 turns on\nlike a low side switch."
		(exclude_from_sim no)
		(at 19.558 110.744 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "3539b5e6-2e8e-4701-bd69-4a43630a33dd")
	)
	(text "Flashing light operation controlled\nby Schmitt Trigger Oscillator.\n\nWhen HV_DETECTED is true, the diode \nis off, and the output oscillates\nat required 2-5 Hz frequency, \nwith 50% duty cycle.\n\nWhen HV_DETECTED is false, the input to\nthe second Schmitt inverter is pulled\nhigh, and the output is low."
		(exclude_from_sim no)
		(at 121.412 191.008 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "42b67719-4d32-44f8-b640-3df34291f148")
	)
