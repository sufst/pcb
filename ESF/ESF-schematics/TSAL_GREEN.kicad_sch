	(text "SCS:\n- Green LED turns on when HV not detected.\n  Safe state = off, so Green LED uses\n  ~{HV_DETECTED} signal \n  (short to GND means off = safe state)"
		(exclude_from_sim no)
		(at 190.246 58.674 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "a04f1207-0bd0-491d-b9d6-bc7171dcfe63")
	)
	(text "If one of the high relays is on,\nand the low relay is on, but no\nhigh voltage is detected for more\nthan ~1s, that implies an \nimplausibility."
		(exclude_from_sim no)
		(at 894.08 511.81 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "a18bdec9-28fc-4374-b4b6-da149475cf8e")
	)
	(text "Low when TS_ON is high.\nHigh when TS_ON is low."
		(exclude_from_sim no)
		(at 732.79 144.78 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "af563b27-49e2-4773-8d04-fa03538fe1cf")
	)
	(text "Close the +ve AIR\nwhen the TS is enabled\nand the inverter commands\nmain contactor closed\n"
		(exclude_from_sim no)
		(at 880.11 106.68 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "bccab7d6-0e79-467b-bba7-f20e3c5227f1")
	)
	(text "For this to go high, the\nfollowing must be true:\n- TS_ON is high (else the\n  latch will be in reset).\n- The shutdown loop has\n  been closed for at least\n  0.47s (else the latch will\n  be in reset).\n- A rising edge on TS_ON\n  has been detected at least\n  0.47s after the shutdown\n  circuit was last open.\n\nThis last point guarantees\nrule EV4.11.4 (FSUK 2024)\n"
		(exclude_from_sim no)
		(at 824.23 149.86 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "bea5285e-37e1-44d7-817f-728128fc3d82")
	)
	(text "Signal from VCU when driver initiates TSON"
		(exclude_from_sim no)
		(at 358.902 57.658 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c27051e6-6049-437e-bef5-b425206f1f34")
	)
	(text "Power"
		(exclude_from_sim no)
		(at 920.75 223.52 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "c44c4ce3-7072-4587-8989-9e10ea15d16d")
	)
	(text "Close the pre-charge relay when the \nTS is enabled and the inverter \ncommands it closed"
		(exclude_from_sim no)
		(at 886.46 161.29 0)
		(effects
			(font
				(size 1.27 1.27)
			)
