	(text "Goes low 0.47s after shutdown\ncircuit closes.\nGoes high 0.01s after shutdown\ncircuit opens."
		(exclude_from_sim no)
		(at 731.52 157.48 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "3d195c7f-9fa5-4cb2-b2f4-131c973a4e8e")
	)
	(text "Goes high 0.1s after TS_ON goes high.\nGoes low immediately after TS_ON\ngoes low.\nRising edge here turns latch on, unless\nit's held in reset. Delay required\nto ensure rising edge happens after\nreset goes low."
		(exclude_from_sim no)
		(at 734.06 97.79 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "413f617e-bf5c-4ddf-a0be-1fecd5121004")
	)
	(text "Any implausibility causes\nthis point to go low"
