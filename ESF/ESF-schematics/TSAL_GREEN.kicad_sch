		(uuid "c69bebe7-dc67-4e4f-9c41-cd70a8529ca1")
	)
	(text "Diode prevents capacitors\nfrom powering the shutdown \nloop when the shutdown loop\nopens, without it the capacitors\non the 12V supply of this board \nwould keep the AIRs on for a short\ntime after the loop opens"
		(exclude_from_sim no)
		(at 986.155 243.205 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "cb00b831-d93b-4519-b021-1955fae1c31a")
	)
	(text "Galvanic isolation between \nTractive System (TS) and Low Voltage (LV) planes\n\n4mm Creepage Distance on PCB\nwith conformal coating\n"
		(exclude_from_sim no)
		(at 156.972 41.656 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
