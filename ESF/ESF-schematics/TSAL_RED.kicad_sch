		(uuid "744bfbea-abaf-4319-9e98-01060ce1a3d2")
	)
	(text "Precision comparator\nmonitors voltage on Ref pin\ncompared to fixed 1.24V\nreference.\nWhen threshold met, current \nflowthrough cathode\nto GND, turning on the LED"
		(exclude_from_sim no)
		(at 119.634 114.554 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "75f915ad-c1b6-49ce-8592-31f7a8b26ff0")
	)
	(text "TSAL Driver PCB - located at top of Roll Hoop"
		(exclude_from_sim no)
		(at 79.248 206.248 0)
		(effects
			(font
				(size 3.5 3.5)
				(thickness 0.4375)
			)
		)
		(uuid "7c014a06-4a04-40e8-8acc-b010a3d825fd")
	)
	(text "1mA"
		(exclude_from_sim no)
		(at 126.492 82.55 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "7d0fba8c-ac21-4a5b-93fa-89ba7831f8b5")
	)
	(text "12V zener"
		(exclude_from_sim no)
		(at 83.058 87.122 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "9878161f-5de2-45bd-94f3-490e0b0735b1")
	)
	(text "TS+ voltage divided across\nfive 200k Ohm resistors.\nPower dissipation divided across string\n\nEach resistor rated for 150V,\nso capable of up to 750V - above the \nmaximum 600V TS Voltage\nand can handle transients"
		(exclude_from_sim no)
		(at 22.606 59.69 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "9e22d181-3738-49e6-8b4a-02ffa9fcb844")
	)
	(text "MOSFETs are used to \namplify + invert signal"
		(exclude_from_sim no)
		(at 183.134 121.92 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "9fbf24f4-2b9a-478f-a857-a5ca14039a0a")
	)
	(text "Constant current LED driver\nSwitching converter to increase efficiency\nLess thermal dissipation compared to linear regulator\n"
		(exclude_from_sim no)
		(at 84.582 217.678 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "a71b52cc-9f95-425a-b15b-7f2c3a57eba4")
	)
	(text "Flashing light operation controlled\nby Schmitt Trigger Oscillator.\n\nWhen HV_DETECTED is true, the diode \nis off, and the output oscillates\nat required 2-5 Hz frequency, \nwith 50% duty cycle.\n\nWhen HV_DETECTED is false, the input to\nthe second Schmitt inverter is pulled\nhigh, and the output is low."
		(exclude_from_sim no)
		(at 122.682 192.278 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "b1719b65-28c1-4c44-b34a-13f6163e4121")
	)
	(text "SCS:\n- Red LED turns on when HV detected.\n  Safe state = off, so red LED uses\n  HV_DETECTED signal \n  (short to GND means off = safe state)"
		(exclude_from_sim no)
		(at 221.996 53.594 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "df25b38b-64ab-4d10-bb4e-79a104065e0c")
	)
	(text "(PCB Integrated with AMS/IMD latching logic)"
		(exclude_from_sim no)
		(at 160.782 147.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
