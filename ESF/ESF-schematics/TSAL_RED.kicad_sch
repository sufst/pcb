		(uuid "bd5fc974-87b9-4a85-8a50-da3ace0859f6")
	)
	(text "TS+ voltage divided across\nfive 200k Ohm resistors.\nPower dissipation divided across string\n\nEach resistor rated for 150V,\nso capable of up to 750V - above the \nmaximum 600V TS Voltage\nand can handle transients"
		(exclude_from_sim no)
		(at 699.516 218.44 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "c1be7266-f6ad-4226-ba70-55043939e99b")
	)
	(text "TS OFF"
		(exclude_from_sim no)
		(at 791.718 699.516 0)
		(effects
			(font
				(size 2 2)
			)
		)
		(uuid "c7c351aa-14c5-47ca-95d5-2639189d6689")
	)
	(text "Weak pull down to ensure safe state\nif wire disconnected"
		(exclude_from_sim no)
		(at 20.32 270.51 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c986f8b9-ac3f-4876-b87a-75677b46da46")
	)
	(text "Close the +ve AIR\nwhen the TS is enabled\nand the inverter commands\nmain contactor closed\n"
		(exclude_from_sim no)
		(at 934.72 454.66 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "cc055ccc-7075-4e36-8a21-a672ac69afbc")
	)
	(text "12V zener"
		(exclude_from_sim no)
		(at 81.788 85.852 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "d31febf0-b58f-4c54-98ec-c979cc36ecb6")
	)
	(text "Rules:\n- The TS should never be enabled if\n  TS_ON is low\n- The TS should only be enabled after\n  a rising edge of the TS_ON input.\n  Whenever the shutdown circuit is opened,\n  the TS should remain off until a\n  rising edge is detected."
		(exclude_from_sim no)
		(at 718.312 470.408 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "d3a00468-5e18-4cbf-8278-e070535daffa")
	)
	(text "Pull down to establish safe state\nin the event of disconnected wire"
		(exclude_from_sim no)
		(at 37.592 175.006 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "d59f05cb-1fec-4089-941f-e4aa6fd1d0ea")
	)
	(text "Filtering of the signal to\nprevent noise causing false detection"
		(exclude_from_sim no)
		(at 81.788 157.48 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "dcb0a348-e184-4326-a2ac-76284d4715b7")
	)
	(text "Time constant 1ms rise,\n2ms fall (through pull-down\nresistor). Asymmetry not\nideal, but not a problem\nbecause the signals are\nslow."
		(exclude_from_sim no)
		(at 770.128 328.422 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "e5bab520-177f-4dc5-bf26-30ca8066a3ee")
	)
	(text "...and this point to go high"
		(exclude_from_sim no)
		(at 854.71 588.01 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "e7d7acf9-2c0a-4acb-ba80-8d3a08ed754b")
	)
	(text "Precision comparator\nmonitors voltage on Ref pin\ncompared to fixed 1.24V\nreference.\nWhen threshold met, current \nflowthrough cathode\nto GND, turning on the LED"
		(exclude_from_sim no)
		(at 118.364 113.284 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e97026d0-ffc9-4334-8e80-489d7f009780")
	)
	(text "Goes high 0.1s after TS_ON goes high.\nGoes low immediately after TS_ON\ngoes low.\nRising edge here turns latch on, unless\nit's held in reset. Delay required\nto ensure rising edge happens after\nreset goes low."
		(exclude_from_sim no)
		(at 788.67 445.77 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "ec66d2d5-6815-44b3-8e25-403f4ef601e6")
	)
	(text "Source follower turns on\nwhen sufficient voltage\non TS line.\nProvides necessary current\nto drive optocoupler LED,\nwithout exposing U13\nto full TS voltage"
		(exclude_from_sim no)
		(at 117.856 42.418 0)
		(effects
