				(size 2.5 2.5)
			)
		)
		(uuid "822b0175-abbd-48fb-8acd-a0210212502b")
	)
	(text "STM32"
		(exclude_from_sim no)
		(at 142.24 110.49 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 132 0 0 1)
			)
		)
		(uuid "a0400f15-7252-458d-8d90-f93880aebd08")
	)
	(text "When the LVMS is power cycled, the STM32\nloses power and restarts.\nThe Program starts from the beginning\nand signals the Visual Check"
		(exclude_from_sim no)
		(at 62.992 121.92 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "b141b486-9ada-4b52-a2ef-ee1f96e8a42d")
	)
	(text "To Dashboard ->"
		(exclude_from_sim no)
		(at 242.824 62.738 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c60bc5dd-d5ff-4f8a-bd1b-103261af5f13")
	)
	(text "To comply with rule T11.9.6, the AMS/IMD Indicators must be illuminated\nfor 1s to 3s for a visible check after power cycling the LVMS.\n\nTo achieve this, the AMS/IMD LED signal is interrupted by the VCU\nto pull the signal low (safe state) by activation of a GPIO pin\nand an open drain level shifter.\n\nThis action happens at the start of the VCU program before the main control loop\nis entered to ensure that it always activates and does not get interrupted.\n"
		(exclude_from_sim no)
		(at 142.24 137.922 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "e647091c-8404-40a3-bb03-9c70cfffeda7")
	)
	(text "OFF"
		(exclude_from_sim no)
		(at 220.218 61.976 0)
		(effects
			(font
				(size 2 2)
			)
		)
		(uuid "f80fa812-4b27-49ed-99f3-fa316c5e4032")
	)
