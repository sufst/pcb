	)
	(text "The VCU sends the Visual Check signal with\nan Active High GPIO Output which is fed \ninto an open drain level shifter"
		(exclude_from_sim no)
		(at 209.55 104.14 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5c9ecd19-725c-4936-bbb2-9be25800a823")
	)
	(text "ON"
		(exclude_from_sim no)
		(at 211.836 61.976 0)
		(effects
			(font
				(size 2 2)
			)
		)
		(uuid "5e76a480-3a0b-42bf-886e-2107bb27312b")
	)
	(text "The level shifter does not drive the signal high\nit can only pull it low (open drain)\n\nWhen it pulls the signal low, the LEDs illuminate\nfor the 2s visual check"
		(exclude_from_sim no)
		(at 74.422 94.234 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "694835ef-c8ac-4c24-9e8b-e7693545e13c")
	)
