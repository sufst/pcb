    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid b2a2d18d-ed6c-46bd-b364-4dc55cd8c8e0)
  )
  (text "This gate disables\nthe SR latch reset\ninput if LVMS is on.\n\nPropagation delay\nof this gate must\nbe shorter than\nthat of delay circuit\nto prevent illegal\nSR latch state"
    (at 122.555 156.21 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid c0e9130c-6f1a-40ab-aec9-0209ed91a8bc)
  )
